---
import Layout from '@/layouts/Layout.astro';

const interests = [
  'Psychotherapy Research in Naturalistic Settings',
  'Long-term Effectiveness of Psychotherapy',
  'Natural Language Processing',
  'Classification of Mental Disorders',
];

const positions = [
  {
    role: 'Gateway Fellow',
    institution: 'Lund University',
    location: 'Lund, Sweden',
    period: 'Feb 2026 – present',
    description: 'International research stay investigating patient-generated language for assessment, interpretation, and prognostic modeling in psychotherapy using AI and NLP.',
    current: true,
  },
  {
    role: 'Postdoctoral Researcher',
    institution: 'Ruhr University Bochum · DZPG',
    location: 'Bochum, Germany',
    period: 'Aug 2023 – present',
    description: 'Leading the psychotherapy research group at the Bochum–Marburg site of the German Center for Mental Health (DZPG), coordinating multi-center research on long-term psychotherapy outcomes and building infrastructure for standardized data collection in routine clinical practice.',
    current: true,
  },
  {
    role: 'Research Assistant',
    institution: 'Ruhr University Bochum · Chair for Clinical Child and Adolescent Psychology',
    location: 'Bochum, Germany',
    period: 'April 2020 – July 2023',
    description: 'PhD Student conducting research on mental health assessment, with a specific focus on the development and evaluation of digital learning tools for psychological diagnostic skills.',
    current: false,
  },

];

const education = [
  {
    degree: 'PhD in Clinical Psychology',
    institution: 'Ruhr University Bochum',
    year: '2024',
    note: 'summa cum laude',
    thesis: "Implicit and explicit categorization processes in clinical psychology: Evidence-based diagnostics, optimal cut-points, and therapists' prototypes",
  },
  {
    degree: 'MSc in Clinical Psychology',
    institution: 'Ruhr University Bochum',
    year: '2018',
    thesis: 'Neural correlates of in-situ exposure in panic disorder with agoraphobia',
    grade: '1.0',
  },
  {
    degree: 'BSc in Psychology',
    institution: 'MLU Halle-Wittenberg',
    year: '2015',
    thesis: 'Physical activity and mood experience in daily life',
    grade: '1.2',
  },
];

const awards = [
  {
    year: '2026',
    title: 'DZPG VISIONS Advanced Grant – POSIDONIA',
    funder: 'BMFTR within the DZPG',
    total: '€1.2M',
    own: '€711,759',
  },
  {
    year: '2025',
    title: 'Gateway Fellowship – META',
    funder: 'RUB Research School',
    total: '€43,903',
    own: null,
  },
  {
    year: '2025',
    title: 'DZPG VISIONS Grant – SAVER',
    funder: 'BMFTR within the DZPG',
    total: '€294,194',
    own: '€135,056',
  },
];
---

<Layout title="Home">

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="flex flex-col md:flex-row md:items-start gap-10">

      <!-- Avatar placeholder (swap with actual image) -->
      <div class="flex-shrink-0">
        <div class="w-28 h-28 rounded-full bg-zinc-200 dark:bg-zinc-800 overflow-hidden ring-2 ring-zinc-200 dark:ring-zinc-700">
          <img
            src="/avatar.jpg"
            alt="Gabriel Bonnin"
            class="w-full h-full object-cover"
            onerror="this.style.display='none'"
          />
        </div>
      </div>

      <!-- Info -->
      <div class="flex-1">
        <h1 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-50 tracking-tight mb-1">
          Gabriel Bonnin
          <span class="text-zinc-400 dark:text-zinc-500 font-normal">, PhD</span>
        </h1>
        <p class="text-base text-zinc-500 dark:text-zinc-400 mb-4">
          Postdoctoral Researcher · Lund University &amp; Ruhr University Bochum
        </p>

        <p class="text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-2xl mb-6">
          I am a postdoc at the Bochum-Marburg site of the German Center for Mental Health (DZPG), based at Ruhr University Bochum, where I lead the psychotherapy research group. Our work centers on multi-center studies exploring the long-term effects of psychotherapy and developing infrastructure for standardized data collection in routine psychotherapeutic care.

Currently, I am on an international research stay at Lund University, where I investigate how patient-generated language can be used for assessment, interpretation, and prognostic modeling in psychotherapy, using methods from artificial intelligence and natural language processing. In addition to my research activities, I am a licensed clinical psychologist and cognitive behavioral therapist.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-3">
          <a href="/publications" class="btn-primary">
            Publications
          </a>
          <a href="/projects" class="btn-outline">
            Projects
          </a>
          <a
            href="/uploads/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline"
          >
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
            CV
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="border-t border-zinc-100 dark:border-zinc-900"></div>

  <!-- Two-column layout for content sections -->
  <div class="max-w-5xl mx-auto px-6 py-14 grid grid-cols-1 lg:grid-cols-3 gap-12">

    <!-- Left column: Bio details -->
    <div class="lg:col-span-2 space-y-12">

      <!-- Research Interests -->
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-4">
          Research Interests
        </h2>
        <ul class="space-y-2">
          {interests.map(interest => (
            <li class="flex items-start gap-2 text-sm text-zinc-600 dark:text-zinc-300">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-zinc-400 dark:bg-zinc-600 flex-shrink-0"></span>
              {interest}
            </li>
          ))}
        </ul>
      </section>

      <!-- Positions -->
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-4">
          Positions
        </h2>
        <div class="space-y-6">
          {positions.map(pos => (
            <div class="flex gap-4">
              <div class="flex flex-col items-center pt-1">
                <div class={`w-2 h-2 rounded-full flex-shrink-0 ${pos.current ? 'bg-emerald-500' : 'bg-zinc-300 dark:bg-zinc-600'}`}></div>
                <div class="w-px flex-1 bg-zinc-200 dark:bg-zinc-800 mt-1"></div>
              </div>
              <div class="pb-6">
                <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 mb-1">
                  <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">{pos.role}</span>
                  {pos.current && (
                    <span class="text-xs font-medium text-emerald-600 dark:text-emerald-400">current</span>
                  )}
                </div>
                <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-0.5">{pos.institution} · {pos.location}</p>
                <p class="text-xs text-zinc-400 dark:text-zinc-500 font-mono mb-2">{pos.period}</p>
                <p class="text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed">{pos.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-4">
          Education
        </h2>
        <div class="space-y-5">
          {education.map(edu => (
            <div>
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
                <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">{edu.degree}</span>
                <span class="text-xs font-mono text-zinc-400 dark:text-zinc-500">{edu.year}</span>
                {edu.note && <span class="text-xs text-zinc-400 dark:text-zinc-500 italic">{edu.note}</span>}
                {edu.grade && <span class="text-xs text-zinc-400 dark:text-zinc-500">grade: {edu.grade}</span>}
              </div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">{edu.institution}</p>
              {edu.thesis && (
                <p class="mt-1 text-xs text-zinc-400 dark:text-zinc-500 italic leading-relaxed">
                  Thesis: {edu.thesis}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Clinical Qualification -->
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-4">
          Clinical Qualification
        </h2>
        <div>
          <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
            <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">Postgraduate training in Cognitive Behavioral Therapy</span>
            <span class="text-xs font-mono text-zinc-400 dark:text-zinc-500">2024</span>
            <span class="text-xs text-zinc-400 dark:text-zinc-500 italic">grade: 1,3</span>
          </div>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">Ruhr University Bochum</p>
        </div>
      </section>

    </div>

    <!-- Right column: Awards & Contact -->
    <div class="space-y-10">

      <!-- Funding -->
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-4">
          Grants &amp; Third-Party Funding
        </h2>
        <div class="space-y-4">
          {awards.map(award => (
            <div class="border-l-2 border-zinc-200 dark:border-zinc-700 pl-3">
              <p class="text-xs font-mono text-zinc-400 dark:text-zinc-500 tabular-nums">{award.year}</p>
              <p class="text-sm font-medium text-zinc-800 dark:text-zinc-200 leading-snug">{award.title}</p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400">{award.funder}</p>
              <p class="text-xs text-zinc-400 dark:text-zinc-500 italic mt-0.5">{award.role}</p>
              <div class="flex gap-4 mt-1.5">
                <span class="text-xs text-zinc-500 dark:text-zinc-400">
                  Total: <span class="font-medium text-zinc-700 dark:text-zinc-300">{award.total}</span>
                </span>
                {award.own && (
                  <span class="text-xs text-zinc-500 dark:text-zinc-400">
                    Own share: <span class="font-medium text-zinc-700 dark:text-zinc-300">{award.own}</span>
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-4">
          Contact
        </h2>
        <div class="space-y-2">
          <a href="mailto:gabriel.bonnin@rub.de" class="flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-300 hover:text-accent-600 dark:hover:text-accent-400 transition-colors">
            <svg class="w-4 h-4 flex-shrink-0 text-zinc-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            gabriel.bonnin@rub.de
          </a>
          <a href="https://orcid.org/0000-0002-7084-8774" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-300 hover:text-accent-600 dark:hover:text-accent-400 transition-colors">
            <svg class="w-4 h-4 flex-shrink-0 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.516.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.897-1.588 3.897-3.722 0-2.016-1.472-3.722-3.872-3.722h-2.322z"/>
            </svg>
            0000-0002-7084-8774
          </a>
          <a href="https://www.researchgate.net/profile/Gabriel-Bonnin" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-300 hover:text-accent-600 dark:hover:text-accent-400 transition-colors">
            <svg class="w-4 h-4 flex-shrink-0 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.586 0c-.818 0-1.508.19-2.073.565-.563.377-.97.936-1.213 1.68a12.193 12.193 0 00-.32 2.973v1.234h-1.907v2.234h1.908v12.083h2.832V8.686h2.254v-2.234h-2.254V4.82c0-.832.078-1.426.243-1.775.165-.35.487-.523.963-.523.306 0 .592.044.854.133v-2.37A6.96 6.96 0 0019.586 0zM4.5 6.434C2.015 6.434 0 8.449 0 10.934c0 2.483 2.015 4.498 4.5 4.498 2.483 0 4.5-2.015 4.5-4.498 0-2.485-2.017-4.5-4.5-4.5zm0 2.25c1.24 0 2.25 1.008 2.25 2.25 0 1.24-1.01 2.248-2.25 2.248S2.25 12.174 2.25 10.934c0-1.242 1.008-2.25 2.25-2.25z"/>
            </svg>
            ResearchGate
          </a>
          <a href="https://www.linkedin.com/in/gabriel-bonnin" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-300 hover:text-accent-600 dark:hover:text-accent-400 transition-colors">
            <svg class="w-4 h-4 flex-shrink-0 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </section>

    </div>
  </div>

</Layout>
