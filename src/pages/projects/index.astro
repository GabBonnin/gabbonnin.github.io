---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const featured = projects.filter(p => p.data.featured);
const other    = projects.filter(p => !p.data.featured);

const allTags = [...new Set(projects.flatMap(p => p.data.tags))].sort();
---

<Layout
  title="Projects"
  description="Research projects by Gabriel Bonnin – psychotherapy, NLP, diagnostic assessment."
>
  <div class="max-w-5xl mx-auto px-6 pt-14 pb-16">

    <!-- Page header -->
    <header class="mb-12">
      <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-50 tracking-tight mb-2">
        Projects
      </h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 max-w-xl">
        Research projects spanning psychotherapy effectiveness, diagnostic assessment,
        and AI/NLP applications in clinical psychology.
      </p>
    </header>

    <!-- Tag filter bar -->
    <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
      <button
        class="tag-btn active text-xs px-3 py-1 rounded-full border transition-colors border-zinc-300 dark:border-zinc-600 bg-zinc-900 dark:bg-zinc-50 text-zinc-50 dark:text-zinc-900"
        data-tag="all"
      >All</button>
      {allTags.map(tag => (
        <button
          class="tag-btn text-xs px-3 py-1 rounded-full border transition-colors border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400 hover:border-zinc-400 dark:hover:border-zinc-500"
          data-tag={tag.toLowerCase()}
        >{tag}</button>
      ))}
    </div>

    <!-- Current / Featured projects -->
    {featured.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-5">
          Current
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {featured.map(project => (
            <ProjectCard
              title={project.data.title}
              date={project.data.date}
              description={project.data.description}
              tags={project.data.tags}
              slug={project.slug}
              externalUrl={project.data.externalUrl}
              featured={project.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    <!-- All other projects -->
    {other.length > 0 && (
      <section>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-5">
          {featured.length > 0 ? 'Previous' : 'All Projects'}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {other.map(project => (
            <ProjectCard
              title={project.data.title}
              date={project.data.date}
              description={project.data.description}
              tags={project.data.tags}
              slug={project.slug}
              externalUrl={project.data.externalUrl}
              featured={false}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards   = document.querySelectorAll<HTMLElement>('article[data-tags]');
  const sections = document.querySelectorAll<HTMLElement>('#tag-filters ~ section');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';

      // Update active button style
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-zinc-900', 'dark:bg-zinc-50', 'text-zinc-50', 'dark:text-zinc-900', 'border-zinc-300', 'dark:border-zinc-600');
        b.classList.add('text-zinc-500', 'dark:text-zinc-400', 'border-zinc-200', 'dark:border-zinc-700');
      });
      btn.classList.add('active', 'bg-zinc-900', 'dark:bg-zinc-50', 'text-zinc-50', 'dark:text-zinc-900', 'border-zinc-300', 'dark:border-zinc-600');
      btn.classList.remove('text-zinc-500', 'dark:text-zinc-400', 'border-zinc-200', 'dark:border-zinc-700');

      // Show/hide cards
      cards.forEach(card => {
        const cardTags = card.dataset.tags ?? '';
        const show = tag === 'all' || cardTags.split(',').includes(tag);
        card.style.display = show ? '' : 'none';
      });

      // Hide section headings if all cards in that section are hidden
      sections.forEach(section => {
        const visible = Array.from(section.querySelectorAll<HTMLElement>('article[data-tags]'))
          .some(c => c.style.display !== 'none');
        section.style.display = visible ? '' : 'none';
      });
    });
  });
</script>
