---
interface Props {
  title: string;
  date: string;
  description: string;
  tags: string[];
  slug: string;
  externalUrl?: string;
  featured?: boolean;
}

const { title, date, description, tags, slug, externalUrl, featured } = Astro.props;
const year = new Date(date).getFullYear();
const href = externalUrl ?? `/projects/${slug}`;
const isExternal = !!externalUrl;
---

<article class="card group">
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex-1 min-w-0">
      <span class="text-xs text-zinc-400 dark:text-zinc-500 font-mono tabular-nums">{year}</span>
      {featured && (
        <span class="ml-2 text-xs font-medium text-accent-600 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/30 px-1.5 py-0.5 rounded">
          Current
        </span>
      )}
    </div>
    <a
      href={href}
      target={isExternal ? '_blank' : undefined}
      rel={isExternal ? 'noopener noreferrer' : undefined}
      aria-label={`View project: ${title}`}
      class="text-zinc-400 dark:text-zinc-600 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors flex-shrink-0"
    >
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        {isExternal
          ? <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          : <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        }
      </svg>
    </a>
  </div>

  <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-50 mb-2 leading-snug group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
    <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
      {title}
    </a>
  </h3>

  <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4 line-clamp-3">
    {description}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</article>
