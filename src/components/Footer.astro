---
const year = new Date().getFullYear();

const links = [
  { href: 'mailto:gabriel.bonnin@rub.de',                         label: 'Email',       icon: 'email'    },
  { href: 'https://orcid.org/0000-0002-7084-8774',                label: 'ORCID',       icon: 'orcid'    },
  { href: 'https://www.researchgate.net/profile/Gabriel-Bonnin',  label: 'ResearchGate',icon: 'rg'       },
  { href: 'https://www.linkedin.com/in/gabriel-bonnin',           label: 'LinkedIn',    icon: 'linkedin' },
];
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 mt-16">
  <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">

    <!-- Left: copyright -->
    <p class="text-xs text-zinc-400 dark:text-zinc-500">
      © {year} Gabriel Bonnin. CC BY-NC-SA 4.0
    </p>

    <!-- Right: social links -->
    <div class="flex items-center gap-5">
      {links.map(link => (
        <a
          href={link.href}
          target={link.href.startsWith('mailto') ? undefined : '_blank'}
          rel="noopener noreferrer"
          aria-label={link.label}
          class="text-xs text-zinc-400 dark:text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>

  </div>
</footer>
