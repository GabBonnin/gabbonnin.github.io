---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PublicationCard from '@/components/PublicationCard.astro';

const allPubs = await getCollection('publications');
const publications = allPubs.sort((a, b) => a.data.order - b.data.order);

type PubType = 'journal' | 'book-chapter' | 'report' | 'thesis' | 'preprint';

const grouped: Record<PubType, typeof publications> = {
  'journal':      publications.filter(p => p.data.type === 'journal'),
  'book-chapter': publications.filter(p => p.data.type === 'book-chapter'),
  'report':       publications.filter(p => p.data.type === 'report'),
  'thesis':       publications.filter(p => p.data.type === 'thesis'),
  'preprint':     publications.filter(p => p.data.type === 'preprint'),
};

const sections: { type: PubType; label: string }[] = [
  { type: 'journal',      label: 'Journal Articles'  },
  { type: 'book-chapter', label: 'Book Chapters'      },
  { type: 'report',       label: 'Reports'            },
  { type: 'thesis',       label: 'Dissertation'       },
];
---

<Layout
  title="Publications"
  description="Publications by Gabriel Bonnin – psychotherapy research, diagnostic assessment, and NLP."
>
  <div class="max-w-5xl mx-auto px-6 pt-14 pb-16">

    <!-- Page header -->
    <header class="mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-2">
        <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-50 tracking-tight">
          Publications
        </h1>
        <a
          href="https://scholar.google.de/citations?user=PE5aaGoAAAAJ&hl=de"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-zinc-400 dark:text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
        >
          Google Scholar ↗
        </a>
      </div>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 max-w-xl">
        Peer-reviewed articles, book chapters, and other scholarly outputs.
        <span class="italic">*</span> Equal contribution.
      </p>
    </header>

    <!-- Sections -->
    {sections.map(({ type, label }) => grouped[type].length > 0 && (
      <section class="mb-12">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-zinc-400 dark:text-zinc-500 mb-5">
          {label}
          <span class="ml-2 font-normal normal-case text-zinc-300 dark:text-zinc-600">
            ({grouped[type].length})
          </span>
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          {grouped[type].map(pub => (
            <PublicationCard
              title={pub.data.title}
              authors={pub.data.authors}
              year={pub.data.year}
              venue={pub.data.venue}
              venueShort={pub.data.venueShort}
              type={pub.data.type}
              doi={pub.data.doi}
              url={pub.data.url}
              abstract={pub.data.abstract}
            />
          ))}
        </div>
      </section>
    ))}

  </div>
</Layout>
