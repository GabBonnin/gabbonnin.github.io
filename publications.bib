@misc{herpertz2026llm,
  title     = {Prevalence, Correlates, and Adverse Effects of Health-Related Large Language Model Use: A Dual-Cohort Study},
  author    = {Herpertz, J. and Hammelrath, L. and Torous, J. and Bonnin, G. and Heim, P. and Knaevelsrud, C. and Richter, M. and Frost, J. and Glaser, N. and Pfrommer, L. and Moor, I. and Behrens, T. and Casjens, S. and Zeeb, H. and Muellmann, S. and Karch, A. and Spallek, L. and Engert, V. and Böttche, M. and ... and Opel, N.},
  year      = {2026},
  journal   = {PsyArXiv},
  shortjournal = {PsyArXiv},
  doi       = {10.31234/osf.io/6e9qkv},
  abstract  = {Large Language Models (LLMs) are increasingly used for health and mental health purposes, yet evidence on associated risks remains scarce. Using a dual-cohort design comprising a general population cohort (N = 28,910) and a clinical cohort of mental health help-seekers (N = 2,313), with adverse effects benchmarked against an outpatient face-to-face psychotherapy cohort (N = 1,775), we investigated the prevalence, correlates, and adverse effects of LLM-based health-seeking behavior. General LLM adoption was associated with sociodemographic early-adopter profiles, whereas general health- and mental health-related use inverted this pattern, being associated with clinical vulnerability. Notably, current psychiatric or psychotherapeutic treatment did not predict either form of health-related use. Adverse effects were more common among clinical cohort members using LLMs for mental health purposes than in the psychotherapy cohort, with the odds of dependency 2.82 times higher (95% CI 2.34, 3.40) and the odds of reduced decision-making autonomy 5.25 times higher (95% CI 3.99, 6.90). While men had lower mental health-related LLM use, they exhibited higher odds of adverse effects than women across both cohorts (OR = 1.50 in the general population cohort and 1.46 in the clinical cohort). Our findings underscore the need for regulatory frameworks and practitioner education to address the unsupervised use of generative AI in healthcare.},
  order     = {4},
}

@misc{bonnin2026scoping,
  title     = {Psychodiagnostische Interviewverfahren über die Lebensspanne: ein Scoping Review},
  author    = {Bonnin, G. and Buys, P. and von Brachel, R.},
  year      = {2026},
  journal   = {PsychArchives},
  shortjournal = {PsychArchives},
  doi       = {10.23668/psycharchives.22152},
  abstract  = {Einleitung: Psychodiagnostische Interviews gelten als Goldstandard in der Diagnostik psychischer Störungen. Trotz ihrer methodischen Vorteile werden strukturierte Interviews in der Routineversorgung selten eingesetzt. Ein zentrales Hindernis ist das Fehlen einer aktuellen, systematischen Übersicht verfügbarer deutschsprachiger Instrumente, ihrer Eigenschaften und psychometrischen Evidenz. Methode: Es wurde ein Scoping Review deutschsprachiger psychodiagnostischer Interviews über die gesamte Lebensspanne durchgeführt. Vier Datenbanken (PubMed, PsycINFO, PsycArticles, PSYNDEX) wurden systematisch durchsucht, ergänzt durch eine Handsuche. Eingeschlossen wurden Studien zur Entwicklung, Adaption oder psychometrischen Evaluation von Breitbandverfahren oder Instrumenten zur Persönlichkeitsdiagnostik auf Basis aktueller Klassifikationssysteme (DSM-5/DSM-5-TR, ICD-10, ICD-11, DC:0-5), die ab dem Jahr 2000 publiziert wurden. Ergebnisse: Insgesamt wurden 51 Quellen zu 23 Interviewverfahren eingeschlossen: drei für das Kleinkindalter, fünf für das Kindes- und Jugendalter sowie 15 für das Erwachsenenalter. Für die meisten Verfahren liegt psychometrische Evidenz vor, die jedoch überwiegend auf einzelne Gütekriterien beschränkt ist. Die methodische Heterogenität der Validierungsstudien schließt direkte Vergleiche aus. Schlussfolgerung: Für den deutschsprachigen Raum existiert eine differenzierte Landschaft psychodiagnostischer Interviews, die weite Teile der Lebensspanne und der gängigen Störungsklassen abdeckt. Bedeutsame Lücken bestehen hinsichtlich ICD-11-Kompatibilität, diagnostischer Breite und methodischer Qualität der Validierungsforschung. Künftige Bemühungen sollten die gründliche Validierung bestehender Verfahren für unterrepräsentierte Störungen und Populationen sowie den gezielten Abbau von Nutzungshürden priorisieren.},
  order     = {5},
}

